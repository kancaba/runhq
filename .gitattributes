# Enforce LF line endings across the repo (fixes Windows CI rustfmt)
* text=auto eol=lf

# Explicit LF for all source/config
*.rs        text eol=lf
*.toml      text eol=lf
*.lock      text eol=lf
*.json      text eol=lf
*.jsonc     text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.md        text eol=lf
*.mdx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.sh        text eol=lf

# Windows-only files keep CRLF
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Lockfiles always LF
Cargo.lock       text eol=lf
pnpm-lock.yaml   text eol=lf
package-lock.json text eol=lf

# Binaries
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.icns      binary
*.webp      binary
*.svg       text eol=lf
*.mp4       binary
*.mov       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
